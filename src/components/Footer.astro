---
const year = new Date().getFullYear();
---

<footer class="border-t border-[#d8d2c4] bg-[#f8f6ee] px-5 py-12 md:px-8 md:py-14">
  <div class="mx-auto flex max-w-7xl flex-col gap-10">
    <div class="flex flex-col items-start justify-between gap-8 md:flex-row md:items-center">
      <div>
        <img
          src="/logo-cleanallandmore.webp"
          alt="Clean all and more"
          width="240"
          height="80"
          class="h-16 w-auto md:h-20"
        />

        <p class="mt-4 text-xs font-medium uppercase tracking-[0.22em] text-[#6f766d]">
          Hausmeisterservice &amp; Gartenpflege
          <br />
          Stuttgart &amp; Umgebung
        </p>
      </div>

      <div class="flex flex-col gap-3 text-[15px] text-[#556055] md:flex-row md:items-center md:gap-8">
        <a
          href="/impressum"
          class="transition hover:text-[#789873]"
        >
          Impressum
        </a>

        <a
          href="/#kontakt"
          class="transition hover:text-[#789873]"
        >
          Kontakt
        </a>

        <a
          href="/datenschutz"
          class="transition hover:text-[#789873]"
        >
          Datenschutz
        </a>

        <button
          id="open-cookie-settings"
          type="button"
          class="text-left transition hover:text-[#789873]"
        >
          Cookie-Einstellungen
        </button>
      </div>
    </div>

    <div class="flex flex-col justify-between gap-3 border-t border-[#d8d2c4] pt-6 text-[13px] text-[#6f766d] md:flex-row">
      <p>© {year} Clean all and more. Alle Rechte vorbehalten.</p>

      <p>Möhringer-Landstr. 14 A · 70563 Stuttgart</p>
    </div>
  </div>
</footer>

<script>
  const cookieSettingsButton = document.querySelector<HTMLButtonElement>(
    "#open-cookie-settings"
  );

  cookieSettingsButton?.addEventListener("click", () => {
    window.dispatchEvent(new Event("open-cookie-settings"));
  });
</script>