---
const whatsappLink =
  "https://wa.me/491727306716?text=Hallo%20Clean%20all%20and%20more,%0A%0Aich%20interessiere%20mich%20f%C3%BCr%20Ihre%20Dienstleistungen%20und%20h%C3%A4tte%20gerne%20ein%20unverbindliches%20Angebot.";

const contactCards = [
  {
    href: whatsappLink,
    icon: "message-circle",
    title: "WhatsApp",
    label: "Schnellste Antwort",
    text: "Schreiben Sie uns direkt und unkompliziert per WhatsApp.",
    action: "Nachricht schreiben",
    highlight: true,
  },
  {
    href: "tel:+491727306716",
    icon: "phone",
    title: "Telefon",
    label: "Persönliche Beratung",
    text: "Rufen Sie uns direkt an – wir freuen uns auf Ihr Projekt.",
    action: "Jetzt anrufen",
    highlight: false,
  },
  {
    href: "mailto:cleanallandmore.stuttgart@gmail.com",
    icon: "mail",
    title: "E-Mail",
    label: "Angebot anfordern",
    text: "Ideal für größere Anfragen oder konkrete Projektbeschreibungen.",
    action: "E-Mail schreiben",
    highlight: false,
  },
];

const infoRows = [
  {
    icon: "map-pin",
    text: "Möhringer-Landstr. 14 A · 70563 Stuttgart",
  },
  {
    icon: "clock",
    text: "Montag – Samstag · 08:00 – 18:00 Uhr",
  },
];

const icons: Record<string, string> = {
  "message-circle":
    '<path d="M21 15a4 4 0 0 1-4 4H8l-5 3V7a4 4 0 0 1 4-4h10a4 4 0 0 1 4 4z"/>',
  phone:
    '<path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6A19.79 19.79 0 0 1 2.12 4.18 2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.12.9.33 1.78.62 2.63a2 2 0 0 1-.45 2.11L8 9.74a16 16 0 0 0 6 6l1.28-1.28a2 2 0 0 1 2.11-.45c.85.29 1.73.5 2.63.62A2 2 0 0 1 22 16.92Z"/>',
  mail:
    '<rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>',
  "map-pin":
    '<path d="M20 10c0 5-8 12-8 12S4 15 4 10a8 8 0 1 1 16 0Z"/><circle cx="12" cy="10" r="3"/>',
  clock:
    '<circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/>',
  check:
    '<path d="m20 6-11 11-5-5"/>',
  arrow:
    '<path d="M5 12h14"/><path d="m13 6 6 6-6 6"/>',
};
---

<section
  id="kontakt"
  class="scroll-mt-40 bg-[#789873] px-5 pt-10 pb-20 md:scroll-mt-48 md:px-8 md:pt-14 md:pb-24"
>
  <div class="mx-auto max-w-7xl">
    <div class="grid gap-14 lg:grid-cols-[0.95fr_0.85fr] lg:items-start lg:gap-24">
      <div class="contact-reveal">
        <p class="text-xs font-semibold uppercase tracking-[0.32em] text-white/75">
          Kontakt
        </p>

        <h2 class="mt-4 text-[30px] font-semibold leading-tight tracking-[-0.04em] text-white md:text-[44px] lg:text-[48px]">
          Lassen Sie uns
          <br />
          über Ihr Projekt sprechen.
        </h2>

        <div class="mt-7 max-w-[430px] overflow-hidden rounded-[28px] border border-white/25 bg-white/15 p-2 shadow-xl shadow-black/10">
          <img
            src="/clean-all-and-more-Nada.webp"
            alt="Clean all and more Ansprechpartnerin"
            class="h-[340px] w-full rounded-[22px] object-cover object-top md:h-[440px]"
          />
        </div>

        <p class="mt-7 max-w-xl text-[16px] leading-8 text-white/85 md:text-[18px]">
          Ob Hausmeisterservice, Gartenpflege oder Gebäudereinigung – wir
          beraten Sie persönlich und erstellen Ihnen kostenlos ein
          unverbindliches Angebot.
        </p>

        <div class="mt-7 flex flex-wrap gap-4 text-sm font-medium text-white/85">
          <span class="flex items-center gap-2">
            <svg
              width="18"
              height="18"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              set:html={icons.check}
            ></svg>
            Kostenloses Angebot
          </span>

          <span class="flex items-center gap-2">
            <svg
              width="18"
              height="18"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              set:html={icons.check}
            ></svg>
            Antwort innerhalb von 24h
          </span>

          <span class="flex items-center gap-2">
            <svg
              width="18"
              height="18"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              set:html={icons.check}
            ></svg>
            Persönliche Beratung
          </span>
        </div>
      </div>

      <div class="contact-reveal-delayed ml-auto grid w-full max-w-[430px] gap-3 md:grid-cols-1 lg:pt-20">
        {
          contactCards.map((card) => (
            <a
              href={card.href}
              target={card.href.startsWith("http") ? "_blank" : undefined}
              rel={card.href.startsWith("http") ? "noopener noreferrer" : undefined}
              class:list={[
                "group relative block overflow-hidden rounded-[24px] border p-[1px] transition-all duration-500 hover:-translate-y-2 hover:scale-[1.015]",
                card.highlight
                  ? "border-white/80 shadow-2xl shadow-black/25"
                  : "border-white/45 shadow-xl shadow-black/15",
              ]}
            >
              <div class="absolute inset-0 bg-gradient-to-br from-white/95 via-white/70 to-[#eef2ea]/90"></div>

              <div class="absolute -right-16 -top-16 h-32 w-32 rounded-full bg-[#789873]/25 blur-2xl transition-all duration-500 group-hover:scale-150 group-hover:bg-[#789873]/40"></div>

              <div class="absolute -bottom-20 -left-20 h-40 w-40 rounded-full bg-white/40 blur-3xl transition-all duration-500 group-hover:scale-125"></div>

              <div class="relative rounded-[23px] bg-white/80 p-4 backdrop-blur-xl transition-all duration-500 group-hover:bg-white/95 group-hover:shadow-2xl group-hover:shadow-black/20">
                <div class="flex items-center justify-between gap-4">
                  <div>
                    <p class="text-[10px] font-bold uppercase tracking-[0.22em] text-[#789873]">
                      {card.label}
                    </p>

                    <h3 class="mt-1 text-lg font-semibold tracking-[-0.02em] text-[#111a13]">
                      {card.title}
                    </h3>
                  </div>

                  <div
                    class:list={[
                      "flex h-12 w-12 shrink-0 items-center justify-center rounded-full shadow-lg transition-all duration-500 group-hover:rotate-6 group-hover:scale-110",
                      card.highlight
                        ? "bg-[#789873] text-white shadow-[#789873]/40"
                        : "bg-[#eef2ea] text-[#789873] shadow-black/10 group-hover:bg-[#789873] group-hover:text-white group-hover:shadow-[#789873]/35",
                    ]}
                  >
                    <svg
                      width="24"
                      height="24"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      set:html={icons[card.icon]}
                    ></svg>
                  </div>
                </div>

                <p class="mt-3 text-[13px] leading-5 text-[#556055]">
                  {card.text}
                </p>

                <div class="mt-4 flex items-center justify-between gap-4">
                  <span class="text-sm font-semibold text-[#789873]">
                    {card.action}
                  </span>

                  <span class="flex h-8 w-8 items-center justify-center rounded-full bg-[#eef2ea] text-[#789873] transition-all duration-500 group-hover:translate-x-1 group-hover:bg-[#789873] group-hover:text-white">
                    <svg
                      width="15"
                      height="15"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      set:html={icons.arrow}
                    ></svg>
                  </span>
                </div>
              </div>
            </a>
          ))
        }

        <div class="mt-5 rounded-[20px] border border-white/25 bg-white/90 p-4 text-[#556055] shadow-lg shadow-black/10">
          <div class="space-y-4 text-sm md:text-[15px]">
            {
              infoRows.map((row) => (
                <div class="flex items-center gap-4">
                  <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-[#eef2ea] text-[#789873]">
                    <svg
                      width="19"
                      height="19"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      set:html={icons[row.icon]}
                    ></svg>
                  </div>

                  <span class="text-[14px] leading-6 text-[#556055]">
                    {row.text}
                  </span>
                </div>
              ))
            }
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .contact-reveal,
  .contact-reveal-delayed {
    opacity: 0;
    transform: translateY(24px);
    animation: contact-fade-up 0.7s ease-out forwards;
  }

  .contact-reveal-delayed {
    animation-delay: 0.1s;
  }

  @keyframes contact-fade-up {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .contact-reveal,
    .contact-reveal-delayed {
      opacity: 1;
      transform: none;
      animation: none;
    }
  }
</style>