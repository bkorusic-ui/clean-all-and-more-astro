---
import BaseLayout from "../layouts/BaseLayout.astro";
import Contact from "../components/Contact.astro";
import References from "../components/References.tsx";
import RelatedServices from "../components/RelatedServices.astro";

const services = [
  "Professioneller Heckenschnitt und Formschnitt",
  "Rückschnitt von Hecken, Sträuchern und Gehölzen",
  "Pflegeschnitt für ein gesundes Wachstum",
  "Saisonaler Heckenschnitt im Frühjahr und Herbst",
  "Entfernung von Wildwuchs und überwachsenen Bereichen",
  "Pflege von Hecken bei Privatgärten, Wohnanlagen und Gewerbeobjekten",
  "Saubere Ausführung mit professionellem Werkzeug",
  "Entsorgung von Schnittgut nach Absprache",
];

const benefits = [
  "Gepflegte und saubere Hecken das ganze Jahr über",
  "Fachgerechter Schnitt für gesundes Wachstum",
  "Ordentliches Erscheinungsbild Ihrer Außenanlage",
  "Ideal für Privatkunden, Unternehmen und Hausverwaltungen",
  "Zuverlässige Termine nach Absprache",
  "Auf Wunsch inklusive Schnittgut-Entsorgung",
];

const steps = [
  ["1", "Anfrage senden", "Sie kontaktieren uns per Formular, Telefon oder WhatsApp."],
  ["2", "Hecke & Umfang klären", "Wir besprechen Größe, Zustand und gewünschten Schnitt."],
  ["3", "Angebot erhalten", "Sie bekommen ein individuelles Angebot für Ihren Heckenschnitt."],
  ["4", "Heckenschnitt durchführen", "Wir schneiden Ihre Hecke zuverlässig, sauber und nach Absprache."],
];

const faqs = [
  [
    "Welche Leistungen gehören zum Heckenschnitt?",
    "Unser Heckenschnitt umfasst Form- und Rückschnitt, Pflegeschnitt für gesundes Wachstum sowie die Entfernung von Wildwuchs bei Hecken, Sträuchern und Gehölzen.",
  ],
  [
    "Wann ist der beste Zeitpunkt für den Heckenschnitt?",
    "Form- und Rückschnitte sind je nach Heckenart im Frühjahr oder Herbst sinnvoll. Stärkere Rückschnitte sollten außerhalb der gesetzlichen Schonzeiten erfolgen. Wir beraten Sie gern passend zu Ihrer Hecke.",
  ],
  [
    "Übernehmen Sie auch regelmäßigen Heckenschnitt?",
    "Ja. Wir übernehmen sowohl einmaligen Heckenschnitt als auch regelmäßige Pflegeintervalle für Privatgärten, Wohnanlagen und Gewerbeobjekte.",
  ],
  [
    "Entsorgen Sie das Schnittgut?",
    "Auf Wunsch kann die Entsorgung des Schnittguts nach Absprache mit übernommen werden.",
  ],
];

const whyPoints = [
  [
    "Gesundes Wachstum",
    "Ein fachgerechter Schnitt fördert dichte, kräftige und gepflegte Hecken.",
  ],
  [
    "Gepflegtes Erscheinungsbild",
    "Saubere Hecken verbessern den ersten Eindruck Ihrer Immobilie und Außenanlage.",
  ],
  [
    "Mehr Ordnung",
    "Regelmäßige Pflege verhindert Wildwuchs und hält Wege, Einfahrten und Grundstücksgrenzen frei.",
  ],
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map(([question, answer]) => ({
    "@type": "Question",
    name: question,
    acceptedAnswer: {
      "@type": "Answer",
      text: answer,
    },
  })),
};

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  serviceType: "Heckenschnitt",
  name: "Heckenschnitt Stuttgart",
  description:
    "Fachgerechter Heckenschnitt für Privatgärten, Wohnanlagen und Unternehmen. Präzise Pflege für gesunde und gepflegte Hecken im Frühjahr und Herbst in Stuttgart, Ludwigsburg und Umgebung.",
  url: "https://www.cleanallandmore.de/heckenschnitt-stuttgart",
  provider: {
    "@type": "LocalBusiness",
    "@id": "https://www.cleanallandmore.de/#unternehmen",
    name: "Clean all and more",
  },
  areaServed: [
    { "@type": "City", name: "Stuttgart" },
    { "@type": "City", name: "Ludwigsburg" },
  ],
  hasOfferCatalog: {
    "@type": "OfferCatalog",
    name: "Leistungen beim Heckenschnitt",
    itemListElement: services.map((item) => ({
      "@type": "Offer",
      itemOffered: {
        "@type": "Service",
        name: item,
      },
    })),
  },
};
---

<BaseLayout
  title="Heckenschnitt | Clean all and more"
  description="Fachgerechter Heckenschnitt für Privatgärten, Wohnanlagen und Unternehmen. Präzise Pflege für gesunde und gepflegte Hecken im Frühjahr und Herbst in Stuttgart, Ludwigsburg und Umgebung."
  canonical="https://www.cleanallandmore.de/heckenschnitt-stuttgart"
>
  <script
    type="application/ld+json"
    set:html={JSON.stringify(serviceSchema)}
  ></script>
  <script
    type="application/ld+json"
    set:html={JSON.stringify(faqSchema)}
  ></script>

  <main class="bg-[#f8f6ee] text-[#111a13]">
    <!-- Hero -->
    <section class="mx-auto grid max-w-7xl grid-cols-1 items-center gap-12 px-5 py-24 md:grid-cols-2 md:px-8 md:py-32">
      <div>
        <p class="text-sm font-semibold uppercase tracking-[0.22em] text-[#789873]">
          Heckenschnitt Stuttgart
        </p>

        <h1 class="mt-5 text-4xl font-semibold leading-[1.05] tracking-[-0.04em] md:text-6xl">
          Professioneller Heckenschnitt in Stuttgart
        </h1>

        <p class="mt-6 max-w-2xl text-lg leading-8 text-[#556055] md:text-xl md:leading-9">
          Clean all and more übernimmt fachgerechten Heckenschnitt,
          Formschnitt und Rückschnitt im Frühjahr und Herbst für
          Privatgärten, Wohnanlagen und Gewerbeobjekte in Stuttgart und
          Umgebung.
        </p>

        <div class="mt-9 flex flex-col gap-3 sm:flex-row">
          <a
            href="#kontakt"
            class="rounded-full bg-[#789873] px-7 py-4 text-center font-semibold text-white shadow-lg shadow-[#789873]/20 transition hover:bg-[#6f8d67]"
          >
            Kostenloses Angebot anfragen
          </a>

          <a
            href="/#leistungen"
            class="rounded-full border border-[#d8d2c4] px-7 py-4 text-center font-semibold transition hover:bg-white"
          >
            Leistungen ansehen
          </a>
        </div>
      </div>

      <div class="overflow-hidden rounded-[32px] shadow-2xl shadow-black/10">
        <img
          src="/images/garden/heckenschnitt-stuttgart-cut3.webp"
          alt="Professioneller Heckenschnitt in Stuttgart"
          width="720"
          height="520"
          loading="eager"
          decoding="async"
          class="h-[320px] w-full object-cover md:h-[520px]"
        />
      </div>
    </section>

    <!-- Einleitung -->
    <section class="mx-auto max-w-5xl px-5 pb-20 md:px-8">
      <h2 class="text-3xl font-semibold tracking-[-0.03em] md:text-4xl">
        Fachgerechter Heckenschnitt für gepflegte Außenanlagen
      </h2>

      <p class="mt-5 text-lg leading-8 text-[#556055]">
        Gepflegte Hecken sorgen für Struktur, Sichtschutz und ein ordentliches
        Erscheinungsbild. Damit Hecken gesund wachsen und dauerhaft schön
        aussehen, ist ein regelmäßiger und fachgerechter Schnitt im Frühjahr
        und Herbst wichtig.
      </p>

      <p class="mt-4 text-lg leading-8 text-[#556055]">
        Wir übernehmen Heckenschnitt in Stuttgart und Umgebung für
        Privatkunden, Wohnanlagen, Unternehmen und Hausverwaltungen. Dabei
        arbeiten wir sauber, zuverlässig und passend zum Zustand Ihrer Hecke.
      </p>
    </section>

    <!-- Warum -->
    <section class="bg-white/45 py-20">
      <div class="mx-auto max-w-6xl px-5 md:px-8">
        <h2 class="text-3xl font-semibold tracking-[-0.03em] md:text-4xl">
          Warum regelmäßiger Heckenschnitt wichtig ist
        </h2>

        <div class="mt-8 grid gap-5 md:grid-cols-3">
          {
            whyPoints.map(([title, text]) => (
              <div class="rounded-3xl border border-[#d8d2c4] bg-[#f8f6ee] p-7">
                <h3 class="text-xl font-semibold">{title}</h3>
                <p class="mt-3 leading-7 text-[#556055]">{text}</p>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <!-- Leistungen -->
    <section class="mx-auto max-w-6xl px-5 py-20 md:px-8">
      <h2 class="text-3xl font-semibold tracking-[-0.03em] md:text-4xl">
        Unsere Leistungen beim Heckenschnitt
      </h2>

      <div class="mt-8 grid gap-5 md:grid-cols-2">
        {
          services.map((item) => (
            <div class="rounded-3xl border border-[#d8d2c4] bg-white/45 p-6 text-[#556055]">
              {item}
            </div>
          ))
        }
      </div>
    </section>

    <!-- Vorteile -->
    <section class="bg-[#111a13] py-20 text-white">
      <div class="mx-auto max-w-6xl px-5 md:px-8">
        <h2 class="text-3xl font-semibold tracking-[-0.03em] md:text-4xl">
          Ihre Vorteile auf einen Blick
        </h2>

        <div class="mt-8 grid gap-4 md:grid-cols-3">
          {
            benefits.map((benefit) => (
              <div class="rounded-2xl border border-white/10 bg-white/5 p-5">
                {benefit}
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <!-- So arbeiten wir -->
    <section class="mx-auto max-w-6xl px-5 py-20 md:px-8">
      <h2 class="text-3xl font-semibold tracking-[-0.03em] md:text-4xl">
        So arbeiten wir
      </h2>

      <div class="mt-8 grid gap-5 md:grid-cols-4">
        {
          steps.map(([number, title, text]) => (
            <div class="rounded-3xl border border-[#d8d2c4] bg-white/45 p-6">
              <div class="flex h-10 w-10 items-center justify-center rounded-full bg-[#789873] font-bold text-white">
                {number}
              </div>
              <h3 class="mt-5 text-lg font-semibold">{title}</h3>
              <p class="mt-3 text-sm leading-7 text-[#556055]">{text}</p>
            </div>
          ))
        }
      </div>
    </section>

    <!-- Einsatzgebiet -->
    <section class="bg-white/45 py-20">
      <div class="mx-auto max-w-5xl px-5 md:px-8">
        <h2 class="text-3xl font-semibold tracking-[-0.03em] md:text-4xl">
          Heckenschnitt in Stuttgart und Umgebung
        </h2>

        <p class="mt-5 text-lg leading-8 text-[#556055]">
          Wir übernehmen Heckenschnitt in Stuttgart und Umgebung für
          Privatgärten, Wohnanlagen, Gewerbeobjekte und Außenanlagen.
        </p>

        <p class="mt-4 text-lg leading-8 text-[#556055]">
          Besonders gefragt ist unser Heckenschnitt bei Kunden, die Wert auf
          gepflegte Grundstücksgrenzen, saubere Außenbereiche und
          regelmäßige Pflege im Frühjahr und Herbst legen.
        </p>
      </div>
    </section>

    <!-- Referenzen -->
    <References client:load />

    <!-- FAQ -->
    <section class="mx-auto max-w-5xl px-5 py-20 md:px-8">
      <h2 class="text-3xl font-semibold tracking-[-0.03em] md:text-4xl">
        Häufige Fragen zum Heckenschnitt
      </h2>

      <div class="mt-8 space-y-5">
        {
          faqs.map(([question, answer]) => (
            <div class="rounded-3xl border border-[#d8d2c4] bg-white/45 p-6">
              <h3 class="text-xl font-semibold">{question}</h3>
              <p class="mt-3 leading-7 text-[#556055]">{answer}</p>
            </div>
          ))
        }
      </div>
    </section>

    <!-- Kontakt -->
    <RelatedServices current="/heckenschnitt-stuttgart" />
    <Contact />
  </main>
</BaseLayout>