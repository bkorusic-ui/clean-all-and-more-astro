---
import BaseLayout from "../layouts/BaseLayout.astro";
import Contact from "../components/Contact.astro";
import References from "../pages/referenzen.astro";
import Breadcrumbs from "../components/Breadcrumbs.astro";


const services = [
  "Regelmäßige Kontrolle von Wohnanlagen und Gewerbeobjekten",
  "Pflege von Eingängen, Wegen und Gemeinschaftsflächen",
  "Kleinere Reparaturen und Instandhaltungsarbeiten",
  "Kontrolle von Beleuchtung, Türen und Außenbereichen",
  "Koordination mit Eigentümern, Mietern und Hausverwaltungen",
  "Zuverlässige Objektbetreuung nach individuellem Bedarf",
];

const benefits = [
  "Persönlicher Ansprechpartner",
  "Zuverlässige Ausführung",
  "Flexible Termine",
  "Alles aus einer Hand",
  "Sauberes Erscheinungsbild Ihrer Immobilie",
  "Ideal für Hausverwaltungen, Eigentümer und Unternehmen",
];

const steps = [
  [
    "1",
    "Kontakt aufnehmen",
    "Sie senden uns Ihre Anfrage per Formular, Telefon oder WhatsApp.",
  ],
  [
    "2",
    "Objekt & Bedarf klären",
    "Wir besprechen, welche Aufgaben regelmäßig übernommen werden sollen.",
  ],
  [
    "3",
    "Angebot erhalten",
    "Sie bekommen ein individuelles Angebot passend zu Ihrer Immobilie.",
  ],
  [
    "4",
    "Betreuung starten",
    "Wir kümmern uns zuverlässig um Ihr Objekt in Stuttgart und Umgebung.",
  ],
];

const faqs = [
  [
    "Für wen eignet sich der Hausmeisterservice?",
    "Unser Hausmeisterservice eignet sich für Hausverwaltungen, Eigentümergemeinschaften, Unternehmen, Vermieter und private Immobilienbesitzer in Stuttgart.",
  ],
  [
    "Welche Aufgaben übernimmt Clean all and more?",
    "Wir übernehmen regelmäßige Objektkontrollen, Pflege von Außenbereichen, kleinere Instandhaltungsarbeiten, Sauberkeit rund um die Immobilie und individuelle Aufgaben nach Absprache.",
  ],
  [
    "Kann ich ein kostenloses Angebot erhalten?",
    "Ja. Sie können uns unverbindlich kontaktieren und erhalten ein individuelles Angebot passend zu Ihrer Immobilie und den gewünschten Leistungen.",
  ],
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map(([question, answer]) => ({
    "@type": "Question",
    name: question,
    acceptedAnswer: {
      "@type": "Answer",
      text: answer,
    },
  })),
};

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  serviceType: "Hausmeisterservice",
  name: "Hausmeisterservice Stuttgart",
  description:
    "Professioneller Hausmeisterservice für Wohnanlagen, Gewerbe und Immobilien. Zuverlässige Objektbetreuung in Stuttgart, Ludwigsburg und Umgebung.",
  url: "https://www.cleanallandmore.de/hausmeisterservice",
  provider: {
    "@type": "LocalBusiness",
    "@id": "https://www.cleanallandmore.de/#unternehmen",
    name: "Clean all and more",
  },
  areaServed: [
    { "@type": "City", name: "Stuttgart" },
    { "@type": "City", name: "Ludwigsburg" },
  ],
  hasOfferCatalog: {
    "@type": "OfferCatalog",
    name: "Leistungen im Hausmeisterservice",
    itemListElement: services.map((item) => ({
      "@type": "Offer",
      itemOffered: {
        "@type": "Service",
        name: item,
      },
    })),
  },
};
---

<BaseLayout
  title="Hausmeisterservice | Clean all and more"
  description="Professioneller Hausmeisterservice für Wohnanlagen, Gewerbe und Immobilien. Zuverlässige Objektbetreuung in Stuttgart, Ludwigsburg und Umgebung."
  canonical="https://www.cleanallandmore.de/hausmeisterservice"
>
  <script
    type="application/ld+json"
    set:html={JSON.stringify(serviceSchema)}
  ></script>
  <script
    type="application/ld+json"
    set:html={JSON.stringify(faqSchema)}
  ></script>

  <main class="bg-[#f8f6ee] text-[#111a13]">
     <Breadcrumbs
        items={[
          {
            name: "Startseite",
            href: "/",
          },
          {
            name: "Hausmeisterservice",
          },
        ]}
      />
    <!-- Hero -->
    <section class="mx-auto grid max-w-7xl grid-cols-1 items-center gap-12 px-5 py-24 md:grid-cols-2 md:px-8 md:py-32">
      <div>
        <p class="text-sm font-semibold uppercase tracking-[0.22em] text-[#789873]">
          Hausmeisterservice Stuttgart
        </p>

        <h1 class="mt-5 text-4xl font-semibold leading-[1.05] tracking-[-0.04em] md:text-6xl">
          Zuverlässiger Hausmeisterservice für Immobilien in Stuttgart und Umgebung
        </h1>

        <p class="mt-6 max-w-2xl text-lg leading-8 text-[#556055] md:text-xl md:leading-9">
          Clean all and more betreut Wohnanlagen, Mehrfamilienhäuser,
          Gewerbeobjekte und Außenbereiche in Stuttgart und Umgebung.
          Persönlich, gründlich und zuverlässig – damit Ihre Immobilie jeden
          Tag einen gepflegten Eindruck macht.
        </p>

        <div class="mt-9 flex flex-col gap-3 sm:flex-row">
          <a
            href="#kontakt"
            class="rounded-full bg-[#789873] px-7 py-4 text-center font-semibold text-white shadow-lg shadow-[#789873]/20 transition hover:bg-[#6f8d67]"
          >
            Kostenloses Angebot anfragen
          </a>

          <a
            href="/#leistungen"
            class="rounded-full border border-[#d8d2c4] px-7 py-4 text-center font-semibold transition hover:bg-white"
          >
            Leistungen ansehen
          </a>
        </div>
      </div>

      <div class="overflow-hidden rounded-[32px] shadow-2xl shadow-black/10">
        <img
          src="/images/hero/hausmeisterservice-gepflegte-wohnanlage-stuttgart.webp"
          alt="Gepflegte Wohnanlage mit Hausmeisterservice in Stuttgart"
          width="720"
          height="520"
          loading="eager"
          decoding="async"
          class="h-[320px] w-full object-cover md:h-[520px]"
        />
      </div>
    </section>

    <!-- Einleitung -->
    <section class="mx-auto max-w-5xl px-5 pb-20 md:px-8">
      <h2 class="text-3xl font-semibold tracking-[-0.03em] md:text-4xl">
        Hausmeisterservice, der Ihre Immobilie zuverlässig entlastet
      </h2>

      <p class="mt-5 text-lg leading-8 text-[#556055]">
        Eine gepflegte Immobilie braucht regelmäßige Aufmerksamkeit. Unser
        Hausmeisterservice in Stuttgart unterstützt Sie bei wiederkehrenden
        Aufgaben rund um Gebäude, Außenanlagen und Gemeinschaftsflächen. So
        bleibt Ihr Objekt sauber, ordentlich und dauerhaft gut betreut.
      </p>

      <p class="mt-4 text-lg leading-8 text-[#556055]">
        Ob Wohnanlage, Gewerbeobjekt oder Mehrfamilienhaus: Wir arbeiten
        zuverlässig, sorgfältig und nach klarer Absprache. Sie erhalten einen
        Service, der zu Ihrem Objekt passt.
      </p>
    </section>

    <!-- Warum Clean all and more -->
    <section class="bg-white/45 py-20">
      <div class="mx-auto max-w-6xl px-5 md:px-8">
        <h2 class="text-3xl font-semibold tracking-[-0.03em] md:text-4xl">
          Warum Clean all and more?
        </h2>

        <div class="mt-8 grid gap-5 md:grid-cols-3">
          {
            [
              [
                "Zuverlässig",
                "Wir erscheinen pünktlich und erledigen vereinbarte Aufgaben sorgfältig.",
              ],
              [
                "Persönlich",
                "Sie haben einen direkten Ansprechpartner für Ihre Immobilie.",
              ],
              [
                "Lokal",
                "Wir sind in Stuttgart und Umgebung im Einsatz.",
              ],
            ].map(([title, text]) => (
              <div class="rounded-3xl border border-[#d8d2c4] bg-[#f8f6ee] p-7">
                <h3 class="text-xl font-semibold">{title}</h3>
                <p class="mt-3 leading-7 text-[#556055]">{text}</p>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <!-- Unsere Leistungen -->
    <section class="mx-auto max-w-6xl px-5 py-20 md:px-8">
      <h2 class="text-3xl font-semibold tracking-[-0.03em] md:text-4xl">
        Unsere Leistungen im Hausmeisterservice
      </h2>

      <div class="mt-8 grid gap-5 md:grid-cols-2">
        {
          services.map((item) => (
            <div class="rounded-3xl border border-[#d8d2c4] bg-white/45 p-6 text-[#556055]">
              {item}
            </div>
          ))
        }
      </div>
    </section>

    <!-- Vorteile -->
    <section class="bg-[#111a13] py-20 text-white">
      <div class="mx-auto max-w-6xl px-5 md:px-8">
        <h2 class="text-3xl font-semibold tracking-[-0.03em] md:text-4xl">
          Ihre Vorteile auf einen Blick
        </h2>

        <div class="mt-8 grid gap-4 md:grid-cols-3">
          {
            benefits.map((benefit) => (
              <div class="rounded-2xl border border-white/10 bg-white/5 p-5">
                {benefit}
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <!-- So arbeiten wir -->
    <section class="mx-auto max-w-6xl px-5 py-20 md:px-8">
      <h2 class="text-3xl font-semibold tracking-[-0.03em] md:text-4xl">
        So arbeiten wir
      </h2>

      <div class="mt-8 grid gap-5 md:grid-cols-4">
        {
          steps.map(([number, title, text]) => (
            <div class="rounded-3xl border border-[#d8d2c4] bg-white/45 p-6">
              <div class="flex h-10 w-10 items-center justify-center rounded-full bg-[#789873] font-bold text-white">
                {number}
              </div>

              <h3 class="mt-5 text-lg font-semibold">{title}</h3>

              <p class="mt-3 text-sm leading-7 text-[#556055]">
                {text}
              </p>
            </div>
          ))
        }
      </div>
    </section>

    <!-- Einsatzgebiete -->
    <section class="bg-white/45 py-20">
      <div class="mx-auto max-w-5xl px-5 md:px-8">
        <h2 class="text-3xl font-semibold tracking-[-0.03em] md:text-4xl">
          Hausmeisterservice in Stuttgart und Umgebung
        </h2>

        <p class="mt-5 text-lg leading-8 text-[#556055]">
          Wir betreuen Immobilien in Stuttgart und Umgebung. Dazu zählen unter
          anderem Wohnanlagen, Mehrfamilienhäuser, Gewerbeobjekte,
          Außenanlagen und private Grundstücke.
        </p>

        <p class="mt-4 text-lg leading-8 text-[#556055]">
          Besonders häufig sind wir für Kunden tätig, die eine zuverlässige,
          regelmäßige und unkomplizierte Betreuung ihrer Immobilie wünschen.
        </p>
      </div>
    </section>

    <!-- Referenzen -->
    <References />

    <!-- FAQ -->
    <section class="mx-auto max-w-5xl px-5 py-20 md:px-8">
      <h2 class="text-3xl font-semibold tracking-[-0.03em] md:text-4xl">
        Häufige Fragen zum Hausmeisterservice
      </h2>

      <div class="mt-8 space-y-5">
        {
          faqs.map(([question, answer]) => (
            <div class="rounded-3xl border border-[#d8d2c4] bg-white/45 p-6">
              <h3 class="text-xl font-semibold">{question}</h3>

              <p class="mt-3 leading-7 text-[#556055]">
                {answer}
              </p>
            </div>
          ))
        }
      </div>
    </section>

    <!-- Kontaktformular -->

    <Contact />
  </main>
</BaseLayout>
